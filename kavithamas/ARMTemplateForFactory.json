						"type": "UTF8"
					},
					{
						"name": "ingestion_timestamp",
						"type": "UTF8"
					},
					{
						"name": "ingestion_time",
						"type": "INT96"
					}
				]
			},
			"dependsOn": [
				"[concat(variables('factoryId'), '/linkedServices/ls_AzureDataLake_Bronze')]"
			]
