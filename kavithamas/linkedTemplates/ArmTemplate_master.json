{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "kavithamas"
		},
		"AzureBlobStorage1_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'AzureBlobStorage1'"
		},
		"AzureDatabricksDeltaLake1_accessToken": {
			"type": "secureString",
			"metadata": "Secure string for 'accessToken' of 'AzureDatabricksDeltaLake1'"
		},
		"AzureSqlDatabase1_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'AzureSqlDatabase1'"
		},
		"ls_AzureDataLake_Bronze_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'ls_AzureDataLake_Bronze'"
		},
		"ls_AzureSql_Retail_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'ls_AzureSql_Retail'"
		},
		"AzureSqlDatabase1_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "kavidatalake2026.database.windows.net"
		},
		"AzureSqlDatabase1_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "retail_metadata_db"
		},
		"AzureSqlDatabase1_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "CloudSA3036f77e"
		},
		"ls_AzureDataLake_Bronze_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://kavidatalake2026.dfs.core.windows.net/"
		},
		"ls_AzureSql_Retail_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "kavidatalake2026.database.windows.net"
		},
		"ls_AzureSql_Retail_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "retail_metadata_db"
		},
		"ls_AzureSql_Retail_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "CloudSA3036f77e"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "kavithamas_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"AzureBlobStorage1_connectionString": {
						"value": "[parameters('AzureBlobStorage1_connectionString')]"
					},
					"AzureDatabricksDeltaLake1_accessToken": {
						"value": "[parameters('AzureDatabricksDeltaLake1_accessToken')]"
					},
					"AzureSqlDatabase1_password": {
						"value": "[parameters('AzureSqlDatabase1_password')]"
					},
					"ls_AzureDataLake_Bronze_accountKey": {
						"value": "[parameters('ls_AzureDataLake_Bronze_accountKey')]"
					},
					"ls_AzureSql_Retail_password": {
						"value": "[parameters('ls_AzureSql_Retail_password')]"
					},
					"AzureSqlDatabase1_properties_typeProperties_server": {
						"value": "[parameters('AzureSqlDatabase1_properties_typeProperties_server')]"
					},
					"AzureSqlDatabase1_properties_typeProperties_database": {
						"value": "[parameters('AzureSqlDatabase1_properties_typeProperties_database')]"
					},
					"AzureSqlDatabase1_properties_typeProperties_userName": {
						"value": "[parameters('AzureSqlDatabase1_properties_typeProperties_userName')]"
					},
					"ls_AzureDataLake_Bronze_properties_typeProperties_url": {
						"value": "[parameters('ls_AzureDataLake_Bronze_properties_typeProperties_url')]"
					},
					"ls_AzureSql_Retail_properties_typeProperties_server": {
						"value": "[parameters('ls_AzureSql_Retail_properties_typeProperties_server')]"
					},
					"ls_AzureSql_Retail_properties_typeProperties_database": {
						"value": "[parameters('ls_AzureSql_Retail_properties_typeProperties_database')]"
					},
					"ls_AzureSql_Retail_properties_typeProperties_userName": {
						"value": "[parameters('ls_AzureSql_Retail_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}